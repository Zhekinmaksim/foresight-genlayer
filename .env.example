# Used by deploy script (npm run deploy)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Set AFTER deploying — used by seed script (npm run seed)
CONTRACT_ADDRESS=0xPASTE_CONTRACT_ADDRESS_HERE

# Frontend env (copy to frontend/.env.local or set in Vercel)
NEXT_PUBLIC_CONTRACT_ADDRESS=0xPASTE_CONTRACT_ADDRESS_HERE
NEXT_PUBLIC_CHAIN=testnet-bradbury
